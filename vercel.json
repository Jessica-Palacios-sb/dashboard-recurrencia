{
  "version": 2,
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "build",
"routes": [
    {
      "src": "/api/facturacion",
      "dest": "/api/salud-cohortes?fuente=facturacion"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}